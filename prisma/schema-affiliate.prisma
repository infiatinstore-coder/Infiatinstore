// This is your Prisma schema file,
// Add these new models for Affiliate/Reseller System

// ========================
// AFFILIATE/RESELLER SYSTEM
// ========================

model Affiliate {
  id              String          @id @default(uuid())
  userId          String          @unique @map("user_id")
  referralCode    String          @unique @map("referral_code")
  commissionRate  Decimal         @default(0.05) @map("commission_rate") @db.Decimal(5, 4) // 5% default
  tier            AffiliateTier   @default(BRONZE)
  totalEarnings   Decimal         @default(0) @map("total_earnings") @db.Decimal(12, 2)
  availableBalance Decimal        @default(0) @map("available_balance") @db.Decimal(12, 2)
  totalReferrals  Int             @default(0) @map("total_referrals")
  status          AffiliateStatus @default(ACTIVE)
  bankAccount     Json?           @map("bank_account") // { bank, accountNumber, accountName }
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  // Relations
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals    AffiliateReferral[]
  commissions  AffiliateCommission[]
  withdrawals  AffiliateWithdrawal[]

  @@map("affiliates")
}

enum AffiliateTier {
  BRONZE   // 5% commission
  SILVER   // 7% commission
  GOLD     // 10% commission
  PLATINUM // 15% commission
}

enum AffiliateStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

model AffiliateReferral {
  id           String   @id @default(uuid())
  affiliateId  String   @map("affiliate_id")
  referredUserId String @map("referred_user_id")
  referredAt   DateTime @default(now()) @map("referred_at")

  // Relations
  affiliate    Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredUser User      @relation(fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([affiliateId, referredUserId])
  @@map("affiliate_referrals")
}

model AffiliateCommission {
  id              String            @id @default(uuid())
  affiliateId     String            @map("affiliate_id")
  orderId         String            @map("order_id")
  orderAmount     Decimal           @map("order_amount") @db.Decimal(12, 2)
  commissionRate  Decimal           @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount Decimal          @map("commission_amount") @db.Decimal(12, 2)
  status          CommissionStatus  @default(PENDING)
  paidAt          DateTime?         @map("paid_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  // Relations
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [orderId], references: [id])

  @@map("affiliate_commissions")
}

enum CommissionStatus {
  PENDING      // Order completed, waiting confirmation
  CONFIRMED    // Ready to be paid
  PAID         // Already paid to affiliate
  CANCELLED    // Order refunded/cancelled
}

model AffiliateWithdrawal {
  id              String           @id @default(uuid())
  affiliateId     String           @map("affiliate_id")
  amount          Decimal          @db.Decimal(12, 2)
  status          WithdrawalStatus @default(PENDING)
  bankAccount     Json             @map("bank_account")
  proofUrl        String?          @map("proof_url")
  notes           String?          @db.Text
  processedBy     String?          @map("processed_by")
  processedAt     DateTime?        @map("processed_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  // Relations
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  @@map("affiliate_withdrawals")
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}
